{
  "name": "nuvio-web-tv-installer",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop installer for Nuvio TV webOS and Samsung Tizen builds.",
  "author": "NuvioMedia",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "@webos-tools/cli": "^3.2.4",
    "@xmldom/xmldom": "^0.8.10",
    "adbhost": "^0.0.2",
    "jszip": "^3.10.1",
    "node-forge": "^1.3.1",
    "tizen": "https://github.com/reisxd/tizen.js/tarball/main"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "space.nuvio.webtvinstaller",
    "productName": "Nuvio WebTV Installer",
    "icon": "icon.png",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "logo/**/*",
      "build/icon.png",
      "installer.config.json",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Nuvio-WebTV-Installer-${version}-Windows.${ext}"
    },
    "mac": {
      "icon": "icon.icns",
      "target": [
        {
          "target": "dir"
        }
      ]
    }
  }
}
